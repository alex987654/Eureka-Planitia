    "refresh": "python3 scripts/fetch_mars_features.py --out public/data"
  },
  "dependencies": {
    "cesium": "^1.121.0"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "vite": "^5.4.8",
    "vite-plugin-cesium": "^1.2.23"
  }
}
